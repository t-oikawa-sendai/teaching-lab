<?xml version="1.0" encoding="UTF-8"?>
<!--
Program:
Lang:
Function:
Note:
Author:Takashi Oikawa
Date:2026/04/17
LastUp:2026/04/17
Update:20260417
-->
<classpath>
	<!-- Java ソースは Dynamic Web Project でも読みやすい Maven 風の配置にします -->
	<classpathentry kind="src" path="src/main/java"/>

	<!-- Web コンテンツ（JSP/CSS 等） -->
	<classpathentry excluding="**/node_modules/*|**/*.min.js|**/bower_components/*" kind="src" path="src/main/webapp"/>

	<!-- 実行に使う JRE（ここは各自の環境で変わっても問題ありません） -->
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>

	<!-- Tomcat 10+（Jakarta Servlet）を前提：ここも各自の環境名に合わせて Eclipse が自動調整します -->
	<classpathentry kind="con" path="org.eclipse.jst.server.core.container/org.eclipse.jst.server.tomcat.runtimeTarget/Tomcat10 (Jakarta)">
		<attributes>
			<attribute name="module" value="true"/>
		</attributes>
	</classpathentry>

	<!-- Dynamic Web Project の標準コンテナ -->
	<classpathentry kind="con" path="org.eclipse.jst.j2ee.internal.web.container"/>
	<classpathentry kind="con" path="org.eclipse.jst.j2ee.internal.module.container"/>

	<!-- コンパイル後 class の出力先 -->
	<classpathentry kind="output" path="bin"/>
</classpath>
